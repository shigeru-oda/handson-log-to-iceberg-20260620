# -----------------------------------------------------------------------------
# Terraform Settings
# -----------------------------------------------------------------------------
# ステート管理: ローカルバックエンド (ロック機構なし)
#
# 【運用制約】
# ローカルバックエンドは自動ロック機構や同時アクセスの検知・防止機能を提供しません。
# 複数のオペレーターが同時に terraform apply / plan を実行すると、ステートファイルの
# 破損やリソースの不整合が発生する可能性があります。
# 必ず一人ずつ順番に Terraform コマンドを実行してください。
# -----------------------------------------------------------------------------

terraform {
  required_version = ">= 1.5"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }

  backend "local" {}
}
